  'Jordan':'рҹҮҜрҹҮҙ','Japan':'рҹҮҜрҹҮө','Saudi Arabia':'рҹҮёрҹҮҰ','South Korea':'рҹҮ°рҹҮ·',
  'Morocco':'рҹҮІрҹҮҰ','Mexico':'рҹҮІрҹҮҪ','Netherlands':'рҹҮірҹҮұ','Norway':'рҹҮірҹҮҙ',
  'New Zealand':'рҹҮірҹҮҝ','Panama':'рҹҮөрҹҮҰ','Paraguay':'рҹҮөрҹҮҫ','Portugal':'рҹҮөрҹҮ№',
  'Qatar':'рҹҮ¶рҹҮҰ','South Africa':'рҹҮҝрҹҮҰ','Scotland':'рҹҸҙу Ғ§у Ғўу Ғіу ҒЈу Ғҙу Ғҝ','Senegal':'рҹҮёрҹҮі',
  'Switzerland':'рҹҮЁрҹҮӯ','Sweden':'рҹҮёрҹҮӘ','Tunisia':'рҹҮ№рҹҮі','TГјrkiye':'рҹҮ№рҹҮ·',
  'Uruguay':'рҹҮәрҹҮҫ','USA':'рҹҮәрҹҮё','Uzbekistan':'рҹҮәрҹҮҝ',
  'Introduction':'вҡҪ','FIFA Museum':'рҹҸӣпёҸ',
};
function flag(country) { return FLAGS[country] || 'рҹҢҗ'; }

// в”Җв”Җв”Җ STATE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const STORAGE_KEY = 'wc2026_tracker';

// Build sections
const SECTIONS = {};
for (const [id,,c] of STICKERS) { if (!SECTIONS[c]) SECTIONS[c]=[]; SECTIONS[c].push(id); }
const COUNTRIES = [...new Set(STICKERS.map(s=>s[2]))].sort();

let collection = {};
try {
  const raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
  // Migrate old string values вҶ’ numbers
  for (const [k, v] of Object.entries(raw)) {
    if (v === 'have')      collection[k] = 1;
    else if (v === 'duplicate') collection[k] = 2;
    else if (typeof v === 'number') collection[k] = v;
  }
} catch {}

// Populate country dropdown
const cf = document.getElementById('country-filter');
COUNTRIES.forEach(c => { const o=document.createElement('option'); o.value=c; o.textContent=c; cf.appendChild(o); });

function save() { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(collection)); } catch {} }
// Returns numeric count for a sticker (0 = missing)
function count(id) { return collection[id] || 0; }
function pctColor(p) { return p===100?'#15803d':p>=75?'#16a34a':p>=50?'#ca8a04':p>=25?'#ea580c':'#9ca3af'; }

// Display config based on count
function cfg(n) {
  if (n === 0) return { icon:'в¬ң', label:'Missing',   color:'#6b7280', bg:'transparent',           rowClass:'' };
  if (n === 1) return { icon:'вң…', label:'Got it Г—1', color:'#15803d', bg:'rgba(22,163,74,.07)',    rowClass:'have' };
  return             { icon:'рҹ”„', label:`Г—${n}`,      color:'#b45309', bg:'rgba(217,119,6,.07)',    rowClass:'duplicate' };
}

// Status filter helper: maps dropdown value to count condition
function matchesStatus(n, status) {
  if (!status)             return true;
  if (status === 'pending')   return n === 0;
  if (status === 'have')      return n >= 1;
  if (status === 'duplicate') return n >= 2;
  return true;
}

// в”Җв”Җв”Җ RENDER STATS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function renderStats() {
  const have   = STICKERS.filter(([id])=>count(id) >= 1).length;
  const dup    = STICKERS.reduce((acc,[id])=>acc + Math.max(0, count(id)-1), 0);
  const needed = STICKERS.length - have;
  const pct    = Math.round(have/STICKERS.length*100);
  document.getElementById('val-total').textContent  = STICKERS.length;
  document.getElementById('val-have').textContent   = have;
  document.getElementById('val-dup').textContent    = dup;
  document.getElementById('val-needed').textContent = needed;
  document.getElementById('overall-pct').textContent = pct+'%';
  document.getElementById('overall-bar').style.width  = pct+'%';
  document.getElementById('overall-sub').innerHTML =
    `<span>вң… ${have} collected</span><span>рҹ”„ ${dup} extra copies</span><span>в¬ң ${needed} still needed</span>`;
}

// в”Җв”Җв”Җ TEAM GRID в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
let currentSort = 'name';
function setSort(s) {
  currentSort = s;
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.toggle('active', b.id==='sort-'+s));
  renderTeamGrid();
}

function renderTeamGrid() {
  const rows = COUNTRIES.map(country => {
    const ids     = SECTIONS[country]||[];
    const have    = ids.filter(id=>count(id) >= 1).length;
    const dup     = ids.reduce((acc,id)=>acc + Math.max(0, count(id)-1), 0);
    const pct     = ids.length ? Math.round(have/ids.length*100) : 0;
    return { country, total:ids.length, have, dup, missing:ids.length-have, pct };
  });
  const sorted = [...rows].sort((a,b)=>
    currentSort==='pct'     ? b.pct-a.pct :
    currentSort==='missing' ? b.missing-a.missing :
    a.country.localeCompare(b.country)
  );
  const complete = rows.filter(r=>r.pct===100).length;
  const none     = rows.filter(r=>r.have===0).length;
  document.getElementById('section-summary').textContent =
    `${complete} teams complete В· ${none} not started`;
  document.getElementById('team-grid').innerHTML = sorted.map(({country,total,have,dup,missing,pct})=>`
    <div class="team-card ${pct===100?'complete':''}" onclick="filterByCountry('${country.replace(/'/g,"\\'")}')">
      <div class="team-card-header">
        <span class="team-name">${pct===100?'вң… ':flag(country)+' '}${country}</span>
        <span class="team-pct" style="color:${pctColor(pct)}">${pct}%</span>
      </div>
      <div class="mini-bar-bg"><div class="mini-bar-fill" style="width:${pct}%;background:${pctColor(pct)}"></div></div>
      <div class="team-sub">
        <span>вң… ${have}/${total}</span>
        ${dup>0?`<span>рҹ”„ +${dup}</span>`:''}
        ${missing>0?`<span>в¬ң ${missing}</span>`:''}
      </div>
    </div>
  `).join('');
}

function filterByCountry(c) {
  document.getElementById('country-filter').value = c;
  document.getElementById('section-body').classList.remove('open');
  document.getElementById('section-chevron').textContent = 'в–ј Show';
  renderList();
  window.scrollTo({ top: document.querySelector('.filters').offsetTop - 70, behavior: 'smooth' });
}

// в”Җв”Җв”Җ SECTION TOGGLE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function toggleSection() {
  const body = document.getElementById('section-body');
  const open = body.classList.toggle('open');
  document.getElementById('section-chevron').textContent = open ? 'в–І Hide' : 'в–ј Show';
  if (open) renderTeamGrid();
}

// в”Җв”Җв”Җ LIST ORDER в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
let listOrder = 'album'; // 'album' | 'az'
function setOrder(order) {
  listOrder = order;
  document.getElementById('order-album').classList.toggle('active', order === 'album');
  document.getElementById('order-az').classList.toggle('active', order === 'az');
  renderList();
}

// в”Җв”Җв”Җ STICKER LIST в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function renderList() {
  const q       = document.getElementById('search').value.trim().toLowerCase();
  const country = document.getElementById('country-filter').value;
  const status  = document.getElementById('status-filter').value;
  const filtered = STICKERS.filter(([id,desc,c]) => {
    if (!matchesStatus(count(id), status)) return false;
    if (country && c!==country)            return false;
    if (q && !id.toLowerCase().includes(q) && !desc.toLowerCase().includes(q) && !c.toLowerCase().includes(q)) return false;
    return true;
  });

  // Apply order
  const displayList = listOrder === 'az'
    ? [...filtered].sort((a, b) => {
        const ac = a[2], bc = b[2];
        // Introduction pinned to top, FIFA Museum pinned to bottom
        const aTop = ac === 'Introduction', bTop = bc === 'Introduction';
        const aBot = ac === 'FIFA Museum',  bBot = bc === 'FIFA Museum';
        if (aTop && bTop) return 0;
        if (aTop) return -1;
        if (bTop) return 1;
        if (aBot && bBot) return 0;
        if (aBot) return 1;
        if (bBot) return -1;
        return ac.localeCompare(bc, 'en');
      })
    : filtered;

  document.getElementById('filter-count').innerHTML =
    `Showing <strong>${displayList.length}</strong> of ${STICKERS.length} stickers &nbsp;В·&nbsp;
     Order: <strong>${listOrder === 'az' ? 'рҹ”Ө AвҖ“Z (English)' : 'рҹ“– Album'}</strong> &nbsp;В·&nbsp;
     <strong>tap</strong> to add a copy &nbsp;В·&nbsp; <strong>long-press</strong> to remove one`;
  const af = document.getElementById('active-filter');
  af.innerHTML = country
    ? `<span class="chip" onclick="clearFilter()">вң• ${flag(country)} ${country}</span>`
    : '';

  const list = document.getElementById('sticker-list');
  if (!displayList.length) { list.innerHTML = '<div class="no-results">No stickers match your filters.</div>'; return; }

  let lastCountry = null;
  list.innerHTML = displayList.map(([id,desc,country,foil]) => {
    const n = count(id); const c = cfg(n);
    let html = '';
    if (country !== lastCountry) {
      lastCountry = country;
      html += `<div class="print-section-break">${flag(country)} ${country}</div>`;
    }
    html += `<div class="sticker-row ${c.rowClass}"
        onclick="addCopy('${id}')"
        oncontextmenu="removeCopy(event,'${id}')"
        ontouchstart="startLongPress(event,'${id}')"
        ontouchend="cancelLongPress()"
        ontouchmove="cancelLongPress()">
      <span class="sticker-icon">${c.icon}</span>
      <span class="sticker-id">${id}</span>
      <span class="sticker-desc">${desc}${foil?'<span class="foil-badge">FOIL</span>':''}</span>
      <span class="sticker-country">${flag(country)} ${country}</span>
      <span class="sticker-status" style="color:${c.color}">${c.label}</span>
    </div>`;
    return html;
  }).join('');
}

function clearFilter() {
  document.getElementById('country-filter').value = '';
  renderList();
}

// Long-press support
let longPressTimer = null;
function startLongPress(e, id) {
  cancelLongPress();
  longPressTimer = setTimeout(() => {
    removeCopy(e, id);
    longPressTimer = null;
  }, 500);
}
function cancelLongPress() {
  if (longPressTimer) { clearTimeout(longPressTimer); longPressTimer = null; }
}

function addCopy(id) {
  collection[id] = (collection[id] || 0) + 1;
  save(); renderStats();
  if (document.getElementById('section-body').classList.contains('open')) renderTeamGrid();
  renderList();
}

function removeCopy(e, id) {
  if (e && e.preventDefault) e.preventDefault();
  const n = collection[id] || 0;
  if (n <= 1) delete collection[id]; else collection[id] = n - 1;
  save(); renderStats();
  if (document.getElementById('section-body').classList.contains('open')) renderTeamGrid();
  renderList();
}

// в”Җв”Җв”Җ SHARE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function openShare() {
  document.getElementById('export-input').value = btoa(JSON.stringify(collection));
  document.getElementById('import-input').value = '';
  document.getElementById('import-msg').className = 'msg';
  document.getElementById('modal').classList.add('open');
}
function closeShare() { document.getElementById('modal').classList.remove('open'); }
function doCopy() {
  const inp = document.getElementById('export-input');
  inp.select(); document.execCommand('copy');
  navigator.clipboard?.writeText(inp.value).catch(()=>{});
  const btn = document.getElementById('copy-btn');
  btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000);
}
function doImport() {
  const msg = document.getElementById('import-msg');
  try {
    const parsed = JSON.parse(atob(document.getElementById('import-input').value.trim()));
    collection = parsed; save();
    msg.textContent = 'Imported successfully!'; msg.className = 'msg success';
    setTimeout(() => { closeShare(); renderAll(); }, 1500);
  } catch {
    msg.textContent = 'Invalid code вҖ” please check and try again.'; msg.className = 'msg error';
  }
}

// в”Җв”Җв”Җ PRINT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function doPrint() {
  // Populate the print-only header with live stats
  const dup     = STICKERS.reduce((acc,[id])=>acc + Math.max(0, count(id)-1), 0);
  const have    = STICKERS.filter(([id])=>count(id) >= 1).length;
  const needed  = STICKERS.length - have;
  const pct     = Math.round(have/STICKERS.length*100);
  const country = document.getElementById('country-filter').value;
  const status  = document.getElementById('status-filter').value;
  const printed = document.querySelectorAll('.sticker-row').length;
  const dateStr = new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});
  const filterDesc = [
    country ? `Team: ${flag(country)} ${country}` : 'All teams',
    status  ? `Status: ${status}`                  : 'All statuses',
  ].join(' В· ');
  document.getElementById('print-meta').innerHTML = `
    <span>Printed: <span class="print-stat">${dateStr}</span></span>
    <span>Overall: <span class="print-stat">${pct}% complete</span></span>
    <span>Got it: <span class="print-stat">${have}</span> &nbsp;В·&nbsp; Duplicate: <span class="print-stat">${dup}</span> &nbsp;В·&nbsp; Still needed: <span class="print-stat">${needed}</span></span>
    <span>Filter: <span class="print-stat">${filterDesc}</span> &nbsp;В·&nbsp; Showing <span class="print-stat">${printed}</span> stickers</span>
  `;
  window.print();
}

// в”Җв”Җв”Җ INIT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function renderAll() { renderStats(); renderList(); }
renderAll();
</script>
</body>
</html>
