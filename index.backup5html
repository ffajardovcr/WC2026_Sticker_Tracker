<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>вҡҪ WC 2026 Sticker Tracker</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --green: #15803d; --green-bg: #f0fdf4; --green-border: #bbf7d0;
    --amber: #b45309; --amber-bg: #fffbeb;
    --blue: #1d4ed8; --gray: #6b7280; --dark: #1f2937;
    --border: #e5e7eb; --surface: #f9fafb; --radius: 10px;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f1f5f9; color: var(--dark); min-height: 100vh; }
  header {
    background: #0f2340; color: white; padding: 0 20px;
    height: 54px; display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,.25);
  }
  header .logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 15px; }
  main { max-width: 960px; margin: 0 auto; padding: 18px 14px; }
  .card { background: white; border: 1px solid var(--border); border-radius: var(--radius); box-shadow: 0 1px 3px rgba(0,0,0,.05); }
  .grid4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 14px; }
  .stat-card { text-align: center; padding: 13px 8px; }
  .stat-card .val { font-size: 24px; font-weight: 700; margin-top: 3px; }
  .stat-card .lbl { font-size: 11px; color: var(--gray); font-weight: 500; }
  .progress-wrap { padding: 16px 18px; margin-bottom: 12px; }
  .progress-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
  .progress-title { font-weight: 700; font-size: 14px; }
  .progress-pct { font-size: 22px; font-weight: 800; color: var(--green); }
  .progress-bar-bg { height: 12px; background: var(--border); border-radius: 99px; overflow: hidden; }
  .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #15803d, #22c55e); border-radius: 99px; transition: width .4s ease; }
  .progress-sub { display: flex; gap: 16px; margin-top: 8px; font-size: 12px; color: var(--gray); }
  .section-panel { margin-bottom: 12px; overflow: hidden; }
  .section-toggle { width: 100%; padding: 13px 18px; text-align: left; background: transparent; border: none; display: flex; align-items: center; justify-content: space-between; font-size: 14px; font-weight: 700; color: var(--dark); cursor: pointer; }
  .section-toggle:hover { background: var(--surface); }
  .section-body { display: none; padding: 0 18px 18px; }
  .section-body.open { display: block; }
  .section-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 8px; }
  .sort-btns { display: flex; gap: 5px; align-items: center; font-size: 11px; color: var(--gray); }
  .sort-btn { padding: 3px 9px; font-size: 11px; border: 1px solid var(--border); border-radius: 5px; cursor: pointer; background: var(--surface); color: var(--dark); font-family: inherit; }
  .sort-btn.active { background: var(--dark); color: white; border-color: var(--dark); }
  .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(158px, 1fr)); gap: 8px; }
  .team-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; cursor: pointer; transition: box-shadow .15s; }
  .team-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,.1); }
  .team-card.complete { background: var(--green-bg); border-color: var(--green-border); }
  .team-card-header { display: flex; justify-content: space-between; align-items: baseline; }
  .team-name { font-size: 12px; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 68%; }
  .team-pct { font-size: 13px; font-weight: 700; flex-shrink: 0; }
  .mini-bar-bg { height: 5px; background: var(--border); border-radius: 99px; overflow: hidden; margin-top: 4px; }
  .mini-bar-fill { height: 100%; border-radius: 99px; transition: width .3s; }
  .team-sub { display: flex; gap: 8px; margin-top: 5px; font-size: 10px; color: #9ca3af; }
  .filters { padding: 12px 14px; margin-bottom: 12px; }
  .filter-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .filter-row input, .filter-row select {
    flex: 1 1 140px; padding: 7px 10px; font-size: 13px;
    border: 1px solid #d1d5db; border-radius: 6px; font-family: inherit;
    background: white; color: var(--dark); outline: none;
  }
  .filter-row input:focus, .filter-row select:focus { border-color: #93c5fd; box-shadow: 0 0 0 3px rgba(59,130,246,.12); }
  .btn { padding: 7px 14px; font-size: 13px; font-weight: 500; border: none; border-radius: 6px; cursor: pointer; font-family: inherit; transition: filter .12s; }
  .btn:hover { filter: brightness(.9); }
  .btn-dark { background: var(--dark); color: white; }
  .btn-ghost { background: white; color: var(--dark); border: 1px solid var(--border); }
  .filter-info { margin-top: 8px; font-size: 12px; color: var(--gray); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .chip { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; padding: 2px 8px; border-radius: 99px; border: 1px solid var(--border); background: white; cursor: pointer; }
  .sticker-list { overflow: hidden; }
  .sticker-row { display: flex; align-items: center; gap: 10px; padding: 9px 14px; border-bottom: 1px solid #f3f4f6; cursor: pointer; transition: filter .12s; user-select: none; }
  .sticker-row:last-child { border-bottom: none; }
  .sticker-row:hover { filter: brightness(.97); }
  .sticker-row.have { background: rgba(22,163,74,.07); }
  .sticker-row.duplicate { background: rgba(217,119,6,.07); }
  .sticker-icon { font-size: 17px; min-width: 20px; text-align: center; }
  .sticker-id { font-family: monospace; font-size: 11px; font-weight: 600; color: #2563eb; min-width: 50px; flex-shrink: 0; }
  .sticker-desc { flex: 1; font-size: 13px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .foil-badge { font-size: 10px; background: #fef3c7; color: #92400e; padding: 1px 5px; border-radius: 3px; margin-left: 6px; vertical-align: middle; font-weight: 600; }
  .sticker-country { font-size: 11px; color: #9ca3af; min-width: 100px; text-align: right; flex-shrink: 0; }
  .sticker-status { font-size: 11px; font-weight: 500; min-width: 55px; text-align: right; flex-shrink: 0; }
  .no-results { padding: 2.5rem; text-align: center; color: #9ca3af; font-size: 13px; }
  /* Modal */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; padding: 16px; }
  .modal-overlay.open { display: flex; }
  .modal { background: white; border-radius: var(--radius); padding: 24px; width: 100%; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,.2); }
  .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .modal-header h3 { font-size: 15px; font-weight: 700; }
  .modal p { font-size: 12px; color: var(--gray); line-height: 1.6; margin-bottom: 14px; }
  .modal label { display: block; font-size: 11px; font-weight: 600; color: #374151; margin-bottom: 5px; }
  .modal .input-row { display: flex; gap: 7px; margin-bottom: 18px; }
  .modal input { font-family: monospace; font-size: 10px; padding: 7px 10px; border: 1px solid #d1d5db; border-radius: 6px; flex: 1; outline: none; }
  .msg { margin-top: 10px; font-size: 12px; padding: 8px 12px; border-radius: 6px; display: none; }
  .msg.success { background: var(--green-bg); color: var(--green); display: block; }
  .msg.error { background: #fee2e2; color: #dc2626; display: block; }
  @media (max-width: 600px) {
    .grid4 { grid-template-columns: repeat(2,1fr); }
    .sticker-country { display: none; }
  }

  /* в”Җв”Җ PRINT STYLES в”Җв”Җ */
  .print-header { display: none; }

  @media print {
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

    body { background: white; font-size: 9px; margin: 0; }
    header, .grid4, .progress-wrap, .section-panel, .filters,
    .modal-overlay, .no-btn-print { display: none !important; }

    main { max-width: 100%; padding: 0; margin: 0; }

    /* Print header */
    .print-header {
      display: block;
      border-bottom: 2px solid #0f2340;
      padding-bottom: 7px;
      margin-bottom: 10px;
    }
    .print-header h1 { font-size: 13px; color: #0f2340; margin-bottom: 3px; }
    .print-header .print-meta { font-size: 8px; color: #6b7280; display: flex; gap: 14px; flex-wrap: wrap; }
    .print-header .print-stat { font-weight: 600; color: #1f2937; }

    /* Two-column sticker grid */
    .card.sticker-list { border: none; box-shadow: none; }
    #sticker-list { columns: 2; column-gap: 10px; }

    /* Section headers span both columns */
    .print-section-break {
      column-span: all;
      display: block;
      font-size: 8px;
      font-weight: 700;
      color: #0f2340;
      background: #e8edf3 !important;
      padding: 2px 5px;
      border-left: 3px solid #0f2340;
      margin-top: 5px;
      margin-bottom: 1px;
      page-break-inside: avoid;
      break-inside: avoid;
    }

    /* Compact sticker rows */
    .sticker-row {
      display: flex !important;
      align-items: center;
      gap: 4px;
      padding: 2px 4px !important;
      border-bottom: 0.5px solid #e5e7eb !important;
      background: transparent !important;
      filter: none !important;
      break-inside: avoid;
      page-break-inside: avoid;
      width: 100%;
    }
    .sticker-row.have      { background: #f0fdf4 !important; }
    .sticker-row.duplicate { background: #fffbeb !important; }

    .sticker-icon   { font-size: 9px !important;  min-width: 12px !important; flex-shrink: 0; }
    .sticker-id     { font-size: 8px !important;   min-width: 36px !important; flex-shrink: 0; font-family: monospace; font-weight: 600; color: #2563eb; }
    .sticker-desc   { font-size: 8px !important;   flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sticker-country { display: none !important; } /* hidden вҖ” section headers already show team */
    .sticker-status { font-size: 8px !important;   min-width: 38px !important; text-align: right; flex-shrink: 0; font-weight: 600; }
    .foil-badge     { font-size: 6px !important;   padding: 0 3px !important; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">вҡҪ WC 2026 Sticker Tracker</div>
  <div style="display:flex;gap:8px">
    <button class="btn btn-ghost no-btn-print" onclick="openShare()" style="font-size:13px;padding:5px 12px;background:transparent;border-color:#374151;color:#d1d5db">рҹ“Ө Share</button>
    <button class="btn btn-ghost no-btn-print" onclick="doPrint()" style="font-size:13px;padding:5px 12px;background:transparent;border-color:#374151;color:#d1d5db">рҹ–ЁпёҸ Print</button>
  </div>
</header>

<main>
  <!-- Print-only header (hidden on screen) -->
  <div class="print-header">
    <h1>вҡҪ FIFA World Cup 2026 вҖ” Panini Sticker Tracker</h1>
    <div class="print-meta" id="print-meta"></div>
  </div>

  <!-- Stat cards -->
  <div class="grid4" id="stat-cards">
    <div class="card stat-card"><div class="lbl">Total stickers</div><div class="val" id="val-total">980</div></div>
    <div class="card stat-card"><div class="lbl">Got it вң…</div><div class="val" id="val-have" style="color:var(--green)">0</div></div>
    <div class="card stat-card"><div class="lbl">Duplicate рҹ”„</div><div class="val" id="val-dup" style="color:var(--amber)">0</div></div>
    <div class="card stat-card"><div class="lbl">Still needed</div><div class="val" id="val-needed" style="color:var(--blue)">980</div></div>
  </div>

  <!-- Overall progress -->
  <div class="card progress-wrap">
    <div class="progress-header">
      <span class="progress-title">Overall completion</span>
      <span class="progress-pct" id="overall-pct">0%</span>
    </div>
    <div class="progress-bar-bg"><div class="progress-bar-fill" id="overall-bar" style="width:0%"></div></div>
    <div class="progress-sub" id="overall-sub"></div>
  </div>

  <!-- Team stats -->
  <div class="card section-panel">
    <button class="section-toggle" onclick="toggleSection()">
      <span>рҹ“Ҡ Completion by Team / Section</span>
      <span id="section-chevron" style="font-size:12px;color:var(--gray);font-weight:400">в–ј Show</span>
    </button>
    <div class="section-body" id="section-body">
      <div class="section-meta">
        <span id="section-summary" style="font-size:12px;color:var(--gray)"></span>
        <div class="sort-btns">
          Sort:
          <button class="sort-btn active" id="sort-name" onclick="setSort('name')">AвҖ“Z</button>
          <button class="sort-btn" id="sort-pct" onclick="setSort('pct')">% done</button>
          <button class="sort-btn" id="sort-missing" onclick="setSort('missing')">missing</button>
        </div>
      </div>
      <div class="team-grid" id="team-grid"></div>
    </div>
  </div>

  <!-- Filters -->
  <div class="card filters">
    <div class="filter-row">
      <input type="text" id="search" placeholder="Search player, code or teamвҖҰ" oninput="renderList()">
      <select id="country-filter" onchange="renderList()">
        <option value="">All teams</option>
      </select>
      <select id="status-filter" onchange="renderList()">
        <option value="">All status</option>
        <option value="pending">в¬ң Missing</option>
        <option value="have">вң… Got it</option>
        <option value="duplicate">рҹ”„ Duplicate</option>
      </select>
      <div style="display:flex;gap:5px;align-items:center;flex-shrink:0">
        <span style="font-size:11px;color:var(--gray);white-space:nowrap">Order:</span>
        <button class="sort-btn active" id="order-album" onclick="setOrder('album')" title="Follow the physical album page order">рҹ“– Album</button>
        <button class="sort-btn"        id="order-az"    onclick="setOrder('az')"    title="Sort alphabetically by country name in English">рҹ”Ө AвҖ“Z</button>
      </div>
    </div>
    <div class="filter-info">
      <span id="filter-count"></span>
      <span id="active-filter"></span>
    </div>
  </div>

  <!-- Sticker list -->
  <div class="card sticker-list" id="sticker-list"></div>
</main>

<!-- Share modal -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeShare()">
  <div class="modal">
    <div class="modal-header">
      <h3>Share / Import Collection</h3>
      <button class="btn btn-ghost" onclick="closeShare()" style="padding:3px 10px">вң•</button>
    </div>
    <p>Copy this code and send via WhatsApp or email. The recipient pastes it in the Import field below to load your exact collection.</p>
    <label>Your collection code</label>
    <div class="input-row">
      <input id="export-input" readonly onclick="this.select()">
      <button class="btn btn-dark" id="copy-btn" onclick="doCopy()">Copy</button>
    </div>
    <label>Import a collection</label>
    <div class="input-row" style="margin-bottom:0">
      <input id="import-input" placeholder="Paste code hereвҖҰ">
      <button class="btn btn-dark" onclick="doImport()">Load</button>
    </div>
    <div class="msg" id="import-msg"></div>
  </div>
</div>

<script>
// в”Җв”Җв”Җ DATA в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const STICKERS = [
["00","Panini Logo","Introduction",true],
["FWC1","Official Emblem","Introduction",true],["FWC2","Official Emblem (variant)","Introduction",true],["FWC3","Official Mascots","Introduction",true],["FWC4","Official Slogan","Introduction",true],["FWC5","Official Ball","Introduction",true],
["FWC6","Canada вҖ“ Host Countries & Cities","Introduction",true],["FWC7","Mexico вҖ“ Host Countries & Cities","Introduction",true],["FWC8","USA вҖ“ Host Countries & Cities","Introduction",true],
["ALG1","Team Logo","Algeria",true],["ALG2","Alexis Guendouz","Algeria",false],["ALG3","Ramy Bensebaini","Algeria",false],["ALG4","Youcef Atal","Algeria",false],["ALG5","Rayan AГҜt-Nouri","Algeria",false],["ALG6","Mohamed Amine Tougai","Algeria",false],["ALG7","AГҜssa Mandi","Algeria",false],["ALG8","Ismael Bennacer","Algeria",false],["ALG9","Houssem Aquar","Algeria",false],["ALG10","Hicham Boudaoui","Algeria",false],["ALG11","Ramiz Zerrouki","Algeria",false],["ALG12","Nabil Bentalab","Algeria",false],["ALG13","Team Photo","Algeria",false],["ALG14","FarГ©s Chaibi","Algeria",false],["ALG15","Riyad Mahrez","Algeria",false],["ALG16","Said Benrahma","Algeria",false],["ALG17","Anis Hadj Moussa","Algeria",false],["ALG18","Amine Gouiri","Algeria",false],["ALG19","Baghdad Bounedjah","Algeria",false],["ALG20","Mohammed Amoura","Algeria",false],
["ARG1","Team Logo","Argentina",true],["ARG2","Emiliano Martinez","Argentina",false],["ARG3","Nahuel Molina","Argentina",false],["ARG4","Cristian Romero","Argentina",false],["ARG5","Nicolas Otamendi","Argentina",false],["ARG6","Nicolas Tagliafico","Argentina",false],["ARG7","Leonardo Balerdi","Argentina",false],["ARG8","Enzo Fernandez","Argentina",false],["ARG9","Alexis Mac Allister","Argentina",false],["ARG10","Rodrigo De Paul","Argentina",false],["ARG11","Exequiel Palacios","Argentina",false],["ARG12","Leandro Paredes","Argentina",false],["ARG13","Team Photo","Argentina",false],["ARG14","Nico Paz","Argentina",false],["ARG15","Franco Mastantuono","Argentina",false],["ARG16","Nico Gonzalez","Argentina",false],["ARG17","Lionel Messi","Argentina",false],["ARG18","Lautaro Martinez","Argentina",false],["ARG19","Julian Alvarez","Argentina",false],["ARG20","Giuliano Simeone","Argentina",false],
["AUS1","Team Logo","Australia",true],["AUS2","Mathew Ryan","Australia",false],["AUS3","Joe Gauci","Australia",false],["AUS4","Harry Souttar","Australia",false],["AUS5","Alessandro Circati","Australia",false],["AUS6","Jordan Bos","Australia",false],["AUS7","Aziz Behich","Australia",false],["AUS8","Cameron Burgess","Australia",false],["AUS9","Lewis Miller","Australia",false],["AUS10","Milos Degenek","Australia",false],["AUS11","Jackson Irvine","Australia",false],["AUS12","Riley McGree","Australia",false],["AUS13","Team Photo","Australia",false],["AUS14","Aiden O'Neill","Australia",false],["AUS15","Connor Metcalfe","Australia",false],["AUS16","Patrick Yazbek","Australia",false],["AUS17","Craig Goodwin","Australia",false],["AUS18","Kusini Vengi","Australia",false],["AUS19","Nestory Irankunda","Australia",false],["AUS20","Mohamed TourГ©","Australia",false],
["AUT1","Team Logo","Austria",true],["AUT2","Alexander Schlager","Austria",false],["AUT3","Patrick Pentz","Austria",false],["AUT4","David Alaba","Austria",false],["AUT5","Kevin Danso","Austria",false],["AUT6","Philipp Lienhart","Austria",false],["AUT7","Stefan Posch","Austria",false],["AUT8","Phillipp Mwene","Austria",false],["AUT9","Alexander Prass","Austria",false],["AUT10","Xaver Schlager","Austria",false],["AUT11","Marcel Sabitzer","Austria",false],["AUT12","Konrad Laimer","Austria",false],["AUT13","Team Photo","Austria",false],["AUT14","Florian Grillitsch","Austria",false],["AUT15","Nicolas Seiwald","Austria",false],["AUT16","Romano Schmid","Austria",false],["AUT17","Patrick Wimmer","Austria",false],["AUT18","Christoph Baumgartner","Austria",false],["AUT19","Michael Gregoritsch","Austria",false],["AUT20","Marko ArnautoviДҮ","Austria",false],
